[Unit]
Description=rpzd DNS Server
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/rpzd
ExecStart=/opt/rpzd/rpzd /opt/rpzd/rpzd.conf
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
RuntimeDirectory=rpzd
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
