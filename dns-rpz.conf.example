# DNS-RPZ bootstrap config
# Copy this file to dns-rpz.conf and fill in your values.
# Lines starting with # are comments. Format: KEY=VALUE

# -------------------------------------------------------
# Database (required)
# -------------------------------------------------------
DATABASE_DSN=postgres://dnsrpz:secret@localhost:5432/dnsrpz
DATABASE_MAX_CONNS=20
DATABASE_MIN_CONNS=2

# -------------------------------------------------------
# Server listen addresses (required)
# -------------------------------------------------------
DNS_ADDRESS=0.0.0.0:53

# -------------------------------------------------------
# Logging (optional)
# LOG_LEVEL controls the initial log level before DB settings are loaded.
# Log format, file output, and rotation are managed via the dashboard.
# -------------------------------------------------------
LOG_LEVEL=info
